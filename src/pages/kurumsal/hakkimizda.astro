---
import SitePageLayout from "@/layouts/SitePageLayout.astro";
import { LandingPageTemplate } from "@/components/templates/LandingPageTemplate";

const imgHakkimizda =
  "https://images.unsplash.com/photo-1523240795612-9a054b0db644?auto=format&fit=crop&w=1200&q=85";

const sections = [
  {
    kind: "intro" as const,
    title: "Biz kimiz?",
    body: "Aktif Kampüs; üniversite öğrencilerini, öğrenci topluluklarını ve gelişim fırsatlarını buluşturan kampüsler arası bir ağdır. Ticari baskıdan uzak, topluluk ve öğrenci yararı öncelikli bir dil kullanır; kampüs içi dayanışma ve fırsat eşitliğini güçlendirmeyi hedefler.",
    tags: ["Topluluk odaklı", "Erişilebilir fırsatlar", "Kampüsler arası bağ"],
  },
  {
    kind: "bullets" as const,
    title: "Sosyal fayda yaklaşımı",
    items: [
      "Öğrenci yararı ve şeffaf iletişim ön planda",
      "Kulüpler, temsilciler ve markalarla uyumlu iş birliği süreçleri",
      "Gençlerin kampüste ve dijitalde görünürlüğünü destekleyen programlar",
    ],
  },
  {
    kind: "model" as const,
    title: "Çalışma modeli",
    body: "Her hizmet (etkinlik, dil, yurtdışı eğitim, temsilcilik, kulüp) ayrı sayfalarda derinlemesine anlatılır; ana sayfa ise bu başlıkları net bir haritayla özetler. Kampüs ihtiyaçlarına göre esnek, tekrarlanabilir bir çerçeveyle ilerleriz.",
    steps: [
      "Kampüs ve kulüp ihtiyaçlarının dinlenmesi",
      "Takvim ve kanalların (duyuru, kayıt, geri bildirim) netleştirilmesi",
      "Yürütme, ölçüm ve dönem sonu değerlendirme",
    ],
  },
  {
    kind: "split" as const,
    title: "Vizyon ve misyon",
    body: "Vizyon: Türkiye’de ve uluslararası düzeyde kampüsler arasında iş birliği kurmak; öğrencilere erişilebilir gelişim alanları sunmak. Misyon: öğrencileri eğitim, kariyer, yabancı dil, sosyal hareketlilik ve uluslararası fırsatlarla buluşturmak.",
    image: imgHakkimizda,
    imageAlt: "Kampüste bir araya gelen öğrenciler",
  },
];
---

<SitePageLayout
  title="Hakkımızda"
  description="Aktif Kampüs kimdir, vizyon ve misyonu nedir? Sosyal fayda odaklı kampüs platformu ve çalışma modelimiz hakkında bilgi."
  currentPath="/kurumsal/hakkimizda"
  contentBleed
>
  <LandingPageTemplate
    client:load
    heroEyebrow="Kurumsal"
    heroTitle="Hakkımızda"
    heroSubtitle="Öğrencilerin gelişim fırsatlarına daha kolay ulaşması ve üniversiteler arasında güçlü etkileşim kurulması için çalışan topluluk odaklı bir kampüs platformu."
    heroStats={[
      { label: "Partner ekosistemi", value: "40+" },
      { label: "İçerik ve rehber", value: "200+" },
      { label: "Aktif şehir", value: "15+" },
    ]}
    heroCta={{ label: "İletişim", href: "/kurumsal/iletisim" }}
    heroSecondaryCta={{ label: "SSS", href: "/kurumsal/sss" }}
    sections={sections}
    closing={{
      title: "Birlikte büyüyelim",
      body: "Kulübün veya kurumunla iş birliği için bize ulaş.",
      cta: { label: "İletişime geç", href: "/kurumsal/iletisim" },
    }}
  />
</SitePageLayout>
