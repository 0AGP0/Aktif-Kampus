---
import SitePageLayout from "@/layouts/SitePageLayout.astro";
import { ListPageTemplate } from "@/components/templates/ListPageTemplate";
import { events } from "@/data/site-content";
---

<SitePageLayout
  title="Üniversite Etkinlikleri | Aktif Kampüs"
  description="Üniversite seminerleri, online webinarlar, kampüs buluşmaları ve bölgesel networking etkinlikleri. Yaklaşan programları tarih ve kategoriye göre inceleyin; ön kayıt için etkinlik detayına gidin."
  currentPath="/etkinlikler"
  contentBleed
  mainFooterGap
>
  <ListPageTemplate
    client:load
    variant="events"
    title="Etkinlikler"
    description="Kampüs temsilciliği buluşmalarından yurtdışı eğitim oturumlarına kadar tüm tarihleri burada süzebilirsiniz. Yer ve online format bilgisi kartta; uzun tanımlar için detay sayfasını açın."
    items={events}
    detailPath="/etkinlikler"
  />
</SitePageLayout>
