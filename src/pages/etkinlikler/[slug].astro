---
import SitePageLayout from "@/layouts/SitePageLayout.astro";
import { DetailPageTemplate } from "@/components/templates/DetailPageTemplate";
import { events, getEventBySlug } from "@/data/site-content";

export function getStaticPaths() {
  return events.map((e) => ({ params: { slug: e.slug } }));
}

const { slug } = Astro.params;
const event = getEventBySlug(slug!);

if (!event) {
  return Astro.redirect("/etkinlikler");
}

const speakerLabel = event.metaThirdLabel ?? "Konuşmacı";

const ortamOnline =
  event.venue.includes("Zoom") || event.venue.includes("Meet")
    ? "Online · Zoom veya Google Meet"
    : "Online";

const meta = [
  { icon: "calendar" as const, label: "Tarih", value: event.when },
  event.mode === "online"
    ? { icon: "monitor" as const, label: "Ortam", value: ortamOnline }
    : { icon: "map" as const, label: "Konum", value: event.venue },
  { icon: "user" as const, label: speakerLabel, value: event.speaker },
];

const pageTitle = `${event.title} | Aktif Kampüs Etkinlikleri`;
---

<SitePageLayout title={pageTitle} description={event.excerpt} currentPath="/etkinlikler">
  <DetailPageTemplate
    client:load
    eyebrow={`Etkinlik · ${event.category}`}
    title={event.title}
    image={event.image}
    imageAlt={event.title}
    imageTag={event.category}
    meta={meta}
    body={event.body}
    ctaLabel={event.ctaLabel ?? "Başvuru / ön kayıt"}
    ctaHref={event.ctaHref ?? "/basvuru/genel"}
  />
</SitePageLayout>
