---
import SitePageLayout from "@/layouts/SitePageLayout.astro";
import { DetailPageTemplate } from "@/components/templates/DetailPageTemplate";
import { getPostBySlug, postsByKind } from "@/data/site-content";

export function getStaticPaths() {
  return postsByKind.blog.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const post = getPostBySlug("blog", slug!);

if (!post) {
  return Astro.redirect("/icerik/blog");
}

const meta = [
  { label: "Kategori", value: post.category },
  { label: "Tarih", value: post.date },
];

const pageTitle = `${post.title} | Aktif Kampüs Blog`;
---

<SitePageLayout title={pageTitle} description={post.excerpt} currentPath="/icerik">
  <DetailPageTemplate
    client:load
    eyebrow="Blog"
    title={post.title}
    image={post.image}
    imageAlt={post.title}
    imageTag={post.category}
    meta={meta}
    body={post.body}
    bodyFigures={post.bodyFigures}
    ctaLabel="Etkinlikler ve başvuru"
    ctaHref="/etkinlikler"
  />
</SitePageLayout>
