---
import SitePageLayout from "@/layouts/SitePageLayout.astro";
import { LandingPageTemplate } from "@/components/templates/LandingPageTemplate";

const img =
  "https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=1200&q=85";

const sections = [
  {
    kind: "intro" as const,
    title: "Üniversite kulüpleri ve topluluklar",
    body: "Öğrenci kulüpleri ve resmi topluluklar; ortak etkinlik, konuşmacı yönlendirmesi, sponsorluk ve tanıtım desteği için Aktif Kampüs ile tek bir koordinasyon hattına bağlanabilir. Amaç üye deneyimini zenginleştirmek, kampüs içi görünürlüğü artırmak ve sosyal fayda odaklı programları şeffaf biçimde duyurmaktır. Ticari baskı yerine topluluk ve öğrenci yararı önceliklidir.",
    tags: ["Kulüp iş birliği", "Ortak etkinlik", "Sponsorluk desteği"],
  },
  {
    kind: "bullets" as const,
    title: "Kulüpler neden iş birliği yapar?",
    items: [
      "Panel, atölye ve kampüs buluşmalarında konuşmacı ve içerik yönlendirmesi",
      "Etkinlik görünürlüğü: duyuru, kayıt ve çok kampüsli tanıtım imkânı",
      "Marka ve kurumlarla uyumlu, ölçülebilir ortak program veya sponsorluk modelleri",
      "Kulüp yönetimi için tek temas noktası ve net teslim takvimi",
    ],
  },
  {
    kind: "model" as const,
    title: "Çalışma modeli",
    body: "Kulübünüzün hedefi, üye profili ve akademik takvime göre esnek bir yol haritası çıkarılır. Ortak etkinlik mi, sponsorluk mu yoksa içerik ortaklığı mı — önce ihtiyaç netleşir, sonra yürütme ve iletişim adımları yazılı hale getirilir.",
    steps: [
      "Kulüp profili, hedef etkinlikler ve bütçe beklentisinin özetlenmesi",
      "Ortak program, konuşmacı veya sponsorluk formatının seçilmesi",
      "Yürütme, duyuru, kayıt ve dönem sonu kısa değerlendirme",
    ],
  },
  {
    kind: "split" as const,
    title: "Ortak üretim ve kampüs takvimi",
    body: "Atölye, panel, sosyal etki projeleri ve çok kampüsli online oturumlar, üniversite etkinlik takvimine uyumlu planlanır. Aktif Kampüs, duyuru metinleri ve kayıt yönlendirmesinde kulüp yönetimine destek verir; katılımcı deneyimi ve erişilebilir dil ön plandadır.",
    image: img,
    imageAlt: "Üniversite kulübü toplantısı ve ortak planlama",
  },
];
---

<SitePageLayout
  title="Üniversite Kulüpleri ve İş Birliği | Aktif Kampüs"
  description="Öğrenci kulüpleri için ortak etkinlik, sponsorluk ve tanıtım desteği. Kampüs etkinlikleri, konuşmacı yönlendirmesi ve kulüp başvurusu — Aktif Kampüs topluluk sayfası."
  currentPath="/kampus/kulupler-topluluklar"
  contentBleed
>
  <LandingPageTemplate
    client:load
    heroEyebrow="Kampüs"
    heroTitle="Kulüpler ve topluluklar"
    heroSubtitle="Kulüp başkanı veya iletişim sorumlusu olarak ortak program, sponsorluk ve içerik iş birliği talep edebilirsin. Üye deneyimini güçlendiren, şeffaf ve ölçülebilir kampüs projeleri için birlikte planlayalım."
    heroStats={[
      { label: "Kulüp partneri", value: "80+" },
      { label: "Ortak proje", value: "150+" },
      { label: "Şehir kapsaması", value: "20+" },
    ]}
    heroCta={{ label: "Kulüp başvurusu", href: "/basvuru/kulup" }}
    heroSecondaryCta={{ label: "Kampüs sayfası", href: "/kampus" }}
    sections={sections}
    closing={{
      title: "Kulübünle başvur",
      body: "Kulüp adı, üye ölçeği, hedef etkinlik veya sponsorluk beklentini formda özetle; ekibimiz uygun formatı önermek için dönüş yapar.",
      cta: { label: "Kulüp başvurusu", href: "/basvuru/kulup" },
    }}
  />
</SitePageLayout>
