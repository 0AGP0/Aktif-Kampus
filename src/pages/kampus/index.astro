---
import SitePageLayout from "@/layouts/SitePageLayout.astro";
import { LandingPageTemplate } from "@/components/templates/LandingPageTemplate";

const imgTemsilcilik =
  "https://images.unsplash.com/photo-1524178232363-1fb2b075b655?auto=format&fit=crop&w=1200&q=85";
const imgKulupler =
  "https://images.unsplash.com/photo-1522202176988-66273c2fd55f?auto=format&fit=crop&w=1200&q=85";

const sections = [
  {
    kind: "intro" as const,
    title: "Kampüs temsilciliği nedir?",
    body: "Aktif Kampüs temsilcisi, kendi üniversitesinde öğrenci topluluğunu duyuran, etkinlik ve seminer takvimini kampüste görünür kılan ve kulüplerle düzenli temas kuran gönüllü veya yarı zamanlı öğrenci lideridir. Duyuru kanalları, kayıt süreçleri ve kampüs içi görünürlük tek çizgide yürütülür; amaç öğrenci fırsatlarını eşit ve erişilebilir biçimde yaymaktır.",
    tags: ["Üniversite temsilciliği", "Öğrenci liderliği", "Kampüs etkinlikleri"],
  },
  {
    kind: "bullets" as const,
    title: "Kampüs ağına neden katılmalısın?",
    items: [
      "Kendi üniversitende görünür bir liderlik ve koordinasyon deneyimi",
      "Etkinlik planlama, iletişim ve topluluk yönetiminde sahada pratik",
      "Kulüpler, mezunlar ve markalarla kampüsler arası bağ kurma fırsatı",
      "Duyuru, içerik ve kayıt süreçlerinde şeffaf, ölçülebilir çalışma alışkanlığı",
    ],
  },
  {
    kind: "model" as const,
    title: "Çalışma modeli",
    body: "Her akademik dönem kampüs takvimine uyumlu, şeffaf ve tekrarlanabilir bir çerçeve kullanılır. Temsilcilik hattı ile kulüp ve topluluk iş birlikleri birbirini tamamlar; tek kanaldan talep toplanır, yönlendirme netleştirilir.",
    steps: [
      "Kampüs öncelikleri ve kulüp ihtiyaçlarının kısa ön değerlendirmesi",
      "Takvim, duyuru ve içerik planının birlikte netleştirilmesi",
      "Etkinlik ve iş birliklerinin yürütülmesi, geri bildirim ve dönem özeti",
    ],
  },
  {
    kind: "split" as const,
    title: "Temsilcilik: başvuru ve süreç",
    body: "Kampüs temsilcisi olmak için başvuru formunu doldurursun; uygunluk ve kampüs yoğunluğuna göre kısa bir ön görüşme yapılır. Oryantasyon sonrası kendi üniversitende mini etkinlik planı, duyuru ritmi ve kulüp temasını Aktif Kampüs ekibiyle uyumlu yürütürsün. Sertifika, networking ve referans gibi avantajlar süreç içinde paylaşılır.",
    image: imgTemsilcilik,
    imageAlt: "Üniversite salonunda kampüs temsilciliği sunumu",
  },
  {
    kind: "split" as const,
    title: "Kulüpler ve topluluklarla ortak hat",
    body: "Öğrenci kulüpleri; ortak etkinlik, konuşmacı yönlendirmesi, sponsorluk ve tanıtım desteği için Aktif Kampüs ile ayrı bir koordinasyon hattına sahiptir. Kulüp başkanı veya iletişim sorumlusu form üzerinden talep iletir; hedef, üye deneyimini zenginleştirmek ve kampüs içi dışı görünürlüğü güçlendirmektir.",
    image: imgKulupler,
    imageAlt: "Üniversite kulübü toplantısı ve ortak planlama",
  },
];
---

<SitePageLayout
  title="Kampüs Temsilciliği ve Üniversite Kulüpleri | Aktif Kampüs"
  description="Üniversite kampüsünde temsilcilik, kulüp iş birliği ve öğrenci toplulukları: Aktif Kampüs ile etkinlik duyurusu, ortak program ve kampüsler arası ağ. Başvuru ve süreç rehberi."
  currentPath="/kampus"
  contentBleed
>
  <LandingPageTemplate
    client:load
    heroEyebrow="Kampüs"
    heroTitle="Kampüsünde söz sahibi ol"
    heroSubtitle="Temsilcilik ve kulüp iş birlikleriyle üniversite öğrencilerini etkinlikler, dil ve yurtdışı programlarıyla buluşturuyoruz. Kendi kampüsünde görünürlük kazan veya kulübünle ortak üret — şeffaf süreç, topluluk odaklı dil."
    heroStats={[
      { label: "Kampüs noktası", value: "30+" },
      { label: "Kulüp iş birliği", value: "50+" },
      { label: "Dönem etkinliği", value: "120+" },
    ]}
    heroCta={{ label: "Temsilcilik detayı", href: "/kampus/temsilcilik" }}
    heroSecondaryCta={{ label: "Kulüpler", href: "/kampus/kulupler-topluluklar" }}
    sections={sections}
    closing={{
      title: "Kampüsüne adım at",
      body: "Temsilci adayıysan temsilcilik formunu; kulüp adına görüşmek istiyorsan kulüp başvurusunu kullan. Üniversite adını ve talebini net yaz; ekibimiz uygun kanaldan dönüş yapar.",
      cta: { label: "Temsilci başvurusu", href: "/basvuru/temsilci" },
    }}
  />
</SitePageLayout>
